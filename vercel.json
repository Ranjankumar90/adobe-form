{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/admin", "destination": "/SETIP/SETIP-INTERNSHIP/admin" },
    { "source": "/SETIP", "destination": "/SETIP/SETIP-INTERNSHIP/index.html" },
    { "source": "/SETIP/SETIP-INTERNSHIP", "destination": "/SETIP/SETIP-INTERNSHIP/index.html" },
    { "source": "/SETIP/SETIP-INTERSHIP", "destination": "/SETIP/SETIP-INTERNSHIP/index.html" },
    { "source": "/webinar", "destination": "/webinar/index.html" },
    { "source": "/data/(.*)", "destination": "/data/$1" }
  ]
}

{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/SETIP", "destination": "/SETIP/index.html" },
    { "source": "/SETIP/(.*)", "destination": "/SETIP/$1" },
    { "source": "/webinar", "destination": "/webinar/index.html" },
    { "source": "/webinar/(.*)", "destination": "/webinar/$1" },
    { "source": "/data/(.*)", "destination": "/data/$1" }
  ]
}
